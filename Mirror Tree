class Node {
    int data;
    Node left, right;

    Node(int data) {
        this.data = data;
        left = right = null;
    }
}

class Solution {

    void mirror(Node root) {

        if (root == null)
            return;

        // Swap left and right child
        Node temp = root.left;
        root.left = root.right;
        root.right = temp;

        // Recursive call
        mirror(root.left);
        mirror(root.right);
    }
}

public class Main {

    public static void main(String[] args) {

        Node a = new Node(3);
        Node b = new Node(4);
        Node c = new Node(2);
        Node d = new Node(-1);
        Node e = new Node(1);
        Node f = new Node(6);
        Node g = new Node(9);

        a.left = b;
        a.right = c;
        b.left = d;
        b.right = e;
        c.left = f;
        c.right = g;

        Solution obj = new Solution();

        obj.mirror(a);

        System.out.println("Mirror Tree Created Successfully.");
    }
}

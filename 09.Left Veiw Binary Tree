import java.util.*;

class Node {
    int data;
    Node left, right;

    Node(int data) {
        this.data = data;
        left = right = null;
    }
}

class Solution {

    public ArrayList<Integer> leftView(Node root) {

        ArrayList<Integer> list = new ArrayList<>();

        if (root == null)
            return list;

        Node nullNode = new Node(-1);

        Queue<Node> q = new LinkedList<>();

        q.add(root);
        q.add(nullNode);

        list.add(root.data);

        while (q.size() > 1) {

            Node curr = q.poll();

            if (curr.data != -1) {

                if (curr.left != null)
                    q.add(curr.left);

                if (curr.right != null)
                    q.add(curr.right);

            } else {

                list.add(q.peek().data);
                q.add(nullNode);
            }
        }

        return list;
    }
}

public class Main {

    public static void main(String[] args) {

        Node a = new Node(3);
        Node b = new Node(4);
        Node c = new Node(2);
        Node d = new Node(-1);
        Node e = new Node(1);
        Node f = new Node(6);
        Node g = new Node(9);

        a.left = b;
        a.right = c;
        b.left = d;
        b.right = e;
        c.left = f;
        c.right = g;

        Solution obj = new Solution();

        ArrayList<Integer> ans = obj.leftView(a);

        System.out.println(ans);
    }
}
